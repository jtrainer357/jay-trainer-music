---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.tagline }}</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <id>{{ site.url }}/</id>
  {%- set lastPost = collections.blog | last -%}
  <updated>{% if lastPost %}{{ lastPost.date | isoDate }}{% else %}2026-01-01T00:00:00.000Z{% endif %}</updated>
  <author>
    <name>{{ site.author }}</name>
  </author>
  {%- for post in collections.blog | reverse | limit(20) %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html"/>
    <id>{{ site.url }}{{ post.url }}</id>
    <published>{{ post.date | isoDate }}</published>
    <updated>{{ post.date | isoDate }}</updated>
    <author>
      <name>{{ site.author }}</name>
    </author>
    <summary>{{ post.data.description or post.data.excerpt or post.data.title }}</summary>
  </entry>
  {%- endfor %}
</feed>
