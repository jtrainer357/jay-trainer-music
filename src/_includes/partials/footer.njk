<!-- FOOTER -->
<footer>
  <div class="footer-top">
    <div>
      <div class="footer-brand-name">Jay Trainer</div>
      <div class="footer-tagline">{{ site.tagline }}</div>
      <p class="footer-bio">Songs born from deep instinct. Folk and acoustic storytelling rooted in place, memory, and the long shadows of old trees.</p>
      <div class="footer-social">
        <a href="{{ site.social.youtube }}" target="_blank" class="social-link" title="YouTube">YT</a>
        <a href="{{ site.social.instagram }}" target="_blank" class="social-link" title="Instagram">IG</a>
        <a href="{{ site.social.twitter }}" target="_blank" class="social-link" title="Twitter">TW</a>
        <a href="{{ site.social.facebook }}" target="_blank" class="social-link" title="Facebook">FB</a>
        <a href="{{ site.social.bandcamp }}" target="_blank" class="social-link" title="Bandcamp">BC</a>
      </div>
    </div>
    <div>
      <div class="footer-col-title">Navigate</div>
      <ul class="footer-links">
        <li><a href="/music/">Music</a></li>
        <li><a href="/merch/">Merch</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/blog/">Journal</a></li>
        <li><a href="/label/">Briar Patch Records</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-title">Music</div>
      <ul class="footer-links">
        {% for release in releases | limit(5) %}
        <li><a href="/music/{{ release.slug }}/">{{ release.shortTitle }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">&copy; {{ 2026 }} Jay Trainer. All rights reserved.</span>
    <span class="footer-motif">made with instinct</span>
  </div>
</footer>
