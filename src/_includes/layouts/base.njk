<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ pageTitle or title }}{% if title != site.title %} — {{ site.title }}{% endif %}</title>

{%- set metaDesc = description or excerpt or site.description -%}
{%- set metaKeywords = keywords or site.keywords -%}
{%- set resolvedImage -%}
  {%- if ogImage -%}
    {%- if ogImage.startsWith('http') -%}{{ ogImage }}{%- else -%}{{ site.url }}{{ ogImage }}{%- endif -%}
  {%- else -%}
    {{ site.url }}{{ site.image }}
  {%- endif -%}
{%- endset -%}
<meta name="description" content="{{ metaDesc }}">
<meta name="author" content="{{ site.author }}">
{% if metaKeywords %}<meta name="keywords" content="{{ metaKeywords | join(', ') if metaKeywords.join else metaKeywords }}">{% endif %}

<!-- Canonical URL -->
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

<!-- Open Graph -->
<meta property="og:title" content="{{ pageTitle or title }}">
<meta property="og:description" content="{{ metaDesc }}">
<meta property="og:image" content="{{ resolvedImage | trim }}">
<meta property="og:image:width" content="{{ site.ogImageWidth }}">
<meta property="og:image:height" content="{{ site.ogImageHeight }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:type" content="{% if tags and 'blog' in tags %}article{% else %}website{% endif %}">
<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:locale" content="{{ site.locale }}">
{% if tags and 'blog' in tags %}
<meta property="article:published_time" content="{{ date | isoDate }}">
<meta property="article:author" content="{{ site.author }}">
{% if keywords %}{%- for kw in keywords %}<meta property="article:tag" content="{{ kw }}">
{% endfor %}{%- endif %}
{% endif %}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="{{ site.twitterHandle }}">
<meta name="twitter:creator" content="{{ site.twitterHandle }}">
<meta name="twitter:title" content="{{ pageTitle or title }}">
<meta name="twitter:description" content="{{ metaDesc }}">
<meta name="twitter:image" content="{{ resolvedImage | trim }}">

<!-- Theme & Icons -->
<meta name="theme-color" content="#3d2b1a">
<link rel="icon" href="/assets/images/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/assets/images/favicon.ico" sizes="48x48">
<link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png">

<!-- RSS Feed -->
<link rel="alternate" type="application/atom+xml" title="{{ site.title }} Feed" href="{{ site.url }}/feed.xml">

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=display=swap" rel="stylesheet">

<!-- Styles -->
<link rel="stylesheet" href="/css/styles.css">
<link rel="stylesheet" href="/css/player.css">
<link rel="stylesheet" href="/css/cart.css">

<!-- Structured Data -->
{% include "partials/structured-data.njk" %}
</head>
<body>

<a href="#main-content" class="skip-to-main">Skip to main content</a>

{% include "partials/nav.njk" %}

<div class="page-stain" aria-hidden="true"></div>
<main id="main-content">
{% block content %}
{{ content | safe }}
{% endblock %}
</main>

<!-- NEWSLETTER (above footer, every page) -->
<section class="newsletter-prefooter">
  <div class="newsletter-prefooter-inner">
    {% include "partials/newsletter-signup.njk" %}
  </div>
</section>

<div class="footer-crease" aria-hidden="true">
  <img src="/assets/images/paper-crease.png" alt="">
</div>
{% include "partials/footer.njk" %}
{% include "partials/player.njk" %}

<!-- All releases data for player -->
<script type="application/json" id="allReleasesData">
{{ releases | dump | safe }}
</script>
{% include "partials/cart-drawer.njk" %}

<script src="/js/router.js" defer></script>
<script src="/js/main.js" defer></script>
<script src="/js/player.js" defer></script>
<script src="/js/cart.js" defer></script>
<script src="/js/newsletter.js" defer></script>
</body>
</html>
